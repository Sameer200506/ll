rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuth() {
      return request.auth != null;
    }
    
    // Helper function to check if the authenticated user matches the UID
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    
    // Helper function to get user profile data
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Helper function to check if the user has admin role
    function isAdmin() {
      return isAuth() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        getUserData().role == 'admin';
    }
    
    // Helper function to check if the user has teacher role
    function isTeacher() {
      return isAuth() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        getUserData().role == 'teacher';
    }

    // Helper function to check if the user is either a teacher or an admin
    function isStaff() {
      return isAdmin() || isTeacher();
    }

    // ─── USERS COLLECTION ──────────────────────────────────────────────────────────
    match /users/{uid} {
      // Users can read their own profile, or staff can read it
      allow read: if isOwner(uid) || isStaff();
      
      // Creating a user profile is allowed during signup. 
      // The role MUST NOT be "admin" during registration.
      allow create: if isOwner(uid) && 
        (request.resource.data.role == 'student' || request.resource.data.role == 'teacher');
        
      // Updates allowed by the user (only name/email, not role) or by admin (everything)
      allow update: if isAdmin() || (
        isOwner(uid) && 
        request.resource.data.role == resource.data.role
      );
      
      // Only admin can delete users
      allow delete: if isAdmin();
    }

    // ─── COURSES COLLECTION ────────────────────────────────────────────────────────
    match /courses/{courseId} {
      // Courses are visible to anyone (including guests browsing the catalog)
      allow read: if true;
      
      // Only teachers and admins can create/update/delete courses
      allow write: if isStaff();
    }

    // ─── LESSONS COLLECTION ────────────────────────────────────────────────────────
    match /lessons/{lessonId} {
      // Lessons are viewable by authenticated users
      allow read: if isAuth();
      
      // Only teachers and admins can create/update/delete lessons
      allow write: if isStaff();
    }

    // ─── RESOURCES COLLECTION ──────────────────────────────────────────────────────
    match /resources/{resourceId} {
      // Resources are viewable by authenticated users
      allow read: if isAuth();
      
      // Only teachers and admins can create/update/delete resources
      allow write: if isStaff();
    }

    // ─── ENROLLMENTS COLLECTION ────────────────────────────────────────────────────
    match /enrollments/{enrollmentId} {
      // A student can read their own enrollments, teachers and admins can read all
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || 
        isStaff()
      );
      
      // Any authenticated user can request/create a new enrollment
      // But the initial status MUST be "pending" (unless they are admin)
      allow create: if isAuth() && (
        request.resource.data.userId == request.auth.uid && 
        (request.resource.data.status == 'pending' || isAdmin())
      );
      
      // Only admins can update (approve/decline) or delete enrollments
      allow update, delete: if isAdmin();
    }

    // ─── PROGRESS COLLECTION ───────────────────────────────────────────────────────
    match /progress/{progressId} {
      // Users can read/write their own progress records, admins can manage all
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || 
        isAdmin()
      );
      allow create, update: if isAuth() && (
        request.resource.data.userId == request.auth.uid || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ─── SCHEDULES COLLECTION ──────────────────────────────────────────────────────
    match /schedules/{scheduleId} {
      // Schedules are readable by authenticated users
      allow read: if isAuth();
      
      // Only teachers and admins can schedule classes
      allow write: if isStaff();
    }

    // ─── QUIZZES COLLECTION ────────────────────────────────────────────────────────
    match /quizzes/{quizId} {
      // Quizzes are readable by authenticated users
      allow read: if isAuth();
      
      // Only teachers and admins can manage quizzes
      allow write: if isStaff();
    }

    // ─── QUIZ RESULTS COLLECTION ───────────────────────────────────────────────────
    match /quizResults/{resultId} {
      // A student can read their own quiz scores, teachers and admins can view all
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || 
        isStaff()
      );
      
      // Authenticated users can write/save their own quiz results
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      
      // Results cannot be modified once submitted (except by admin)
      allow update, delete: if isAdmin();
    }

    // ─── PROJECTS COLLECTION ───────────────────────────────────────────────────────
    match /projects/{projectId} {
      // A student can read their own projects, teachers and admins can view all
      allow read: if isAuth() && (
        resource.data.studentId == request.auth.uid || 
        isStaff()
      );
      
      // Only teachers and admins can assign (create) projects
      allow create: if isStaff();
      
      // Updates:
      // - Students can ONLY update their submission link & status to "submitted"
      // - Teachers and admins can update everything (grading, feedback, etc.)
      allow update: if isStaff() || (
        isAuth() && 
        resource.data.studentId == request.auth.uid && 
        request.resource.data.studentId == resource.data.studentId &&
        request.resource.data.courseId == resource.data.courseId &&
        request.resource.data.title == resource.data.title &&
        request.resource.data.grade == resource.data.grade && 
        request.resource.data.feedback == resource.data.feedback
      );
      
      // Only admins can delete projects
      allow delete: if isAdmin();
    }

    // ─── LEADS COLLECTION ──────────────────────────────────────────────────────────
    match /leads/{leadId} {
      // Anyone can submit a lead (e.g. contact form submissions)
      allow create: if true;
      
      // Only admins can read, update, or delete lead messages
      allow read, update, delete: if isAdmin();
    }

    // ─── ATTENDANCE COLLECTION ─────────────────────────────────────────────────────
    match /attendance/{attendanceId} {
      // Only teachers and admins can read, record, or modify attendance logs
      allow read, write: if isStaff();
    }

    // ─── SITE SETTINGS COLLECTION ──────────────────────────────────────────────────
    match /settings/{docId} {
      // Anyone can read site settings (logo, text, curricula, whatsapp configurations)
      allow read: if true;
      
      // Only admins can update site settings
      allow write: if isAdmin();
    }

    // ─── NOTIFICATIONS COLLECTION ──────────────────────────────────────────────────
    match /notifications/{notificationId} {
      // Users can read/update notifications directed to them (e.g. marking read)
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow update: if isAuth() && 
        resource.data.userId == request.auth.uid && 
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.message == resource.data.message;
        
      // Creating notifications is restricted to teachers and admins
      allow create: if isStaff();
      
      // Deletion restricted to admins
      allow delete: if isAdmin();
    }
    
    // ─── CERTIFICATES COLLECTION ───────────────────────────────────────────────────
    match /certificates/{certificateId} {
      // Anyone can verify a certificate (read access is open for public verification)
      allow read: if true;
      
      // Only admins can issue (create) or delete certificates
      allow write: if isAdmin();
    }
  }
}
