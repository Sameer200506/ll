# Force HTTPS and configure fallback routing for SPA pages
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Force HTTPS redirect
    RewriteCond %{HTTPS} !=on
    RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

    # Serve index.html directly for root
    DirectoryIndex index.html

    # Strip trailing slash from non-directories (or directories without index.html) to prevent 404s
    RewriteCond %{REQUEST_FILENAME} !-d [OR]
    RewriteCond %{REQUEST_FILENAME}/index.html !-f
    RewriteCond %{REQUEST_URI} ^(.+)/$
    RewriteRule ^ %1 [R=301,L]

    # Serve the .html file directly if it exists (e.g. /admin -> /admin.html)
    # This must run BEFORE the directory check because folders like /admin and /dashboard/student/courses exist on disk
    # to hold dynamic sub-routes, causing Apache to return 404/403 when trying to serve them as directories.
    RewriteCond %{DOCUMENT_ROOT}/$1.html -f
    RewriteRule ^(.*)$ $1.html [L]

    # Serve real files or directories
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Fallbacks for dynamic client-side routes (serving the default templates for hydration)
    
    # /certificates/xyz -> /certificates/default.html
    RewriteRule ^certificates/([^/]+)$ certificates/default.html [L]

    # /courses/xyz -> /courses/default.html
    RewriteRule ^courses/([^/]+)$ courses/default.html [L]

    # /admin/courses/xyz -> /admin/courses/default.html
    RewriteRule ^admin/courses/([^/]+)$ admin/courses/default.html [L]

    # /dashboard/student/courses/xyz -> /dashboard/student/courses/default.html
    RewriteRule ^dashboard/student/courses/([^/]+)$ dashboard/student/courses/default.html [L]

    # /dashboard/student/tests/xyz -> /dashboard/student/tests/default.html
    RewriteRule ^dashboard/student/tests/([^/]+)$ dashboard/student/tests/default.html [L]

    # /dashboard/teacher/courses/xyz -> /dashboard/teacher/courses/default.html
    RewriteRule ^dashboard/teacher/courses/([^/]+)$ dashboard/teacher/courses/default.html [L]
</IfModule>

# Set Security Headers
<IfModule mod_headers.c>
    # Enforce HTTPS via Strict-Transport-Security (HSTS) - 2 years max-age with subdomains and preload
    Header always set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
    
    # Prevent browsers from MIME-sniffing the response away from the declared Content-Type
    Header always set X-Content-Type-Options "nosniff"
    
    # Control how much referrer information the browser includes with requests
    Header always set Referrer-Policy "no-referrer-when-downgrade"
    
    # Prevent clickjacking attacks by only allowing frames from the same origin
    Header always set X-Frame-Options "SAMEORIGIN"
    
    # Enable browser XSS protection block mode
    Header always set X-XSS-Protection "1; mode=block"
    
    # Content Security Policy (CSP) - restricted to trusted domains for Firebase, Google Fonts, and Google APIs
    # Added blob: to script-src and img-src to accommodate local PDF/certificate rendering and blob files.
    # Added https://*.vercel.app to img-src to permit historical/transitional thumbnails.
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob: https://apis.google.com https://www.gstatic.com https://www.google-analytics.com https://ssl.google-analytics.com; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com https://*.firebasestorage.app https://firebasestorage.googleapis.com https://www.google-analytics.com; img-src 'self' data: blob: https://*.vercel.app https://*.googleapis.com https://*.firebaseimages.com https://*.firebasestorage.app https://firebasestorage.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; frame-src 'self' https://*.firebaseapp.com https://lmss-91637.firebaseapp.com; object-src 'none';"
</IfModule>
